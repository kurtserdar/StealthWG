# Copy to .env and edit. Only PUBLIC_HOST is required.

# Public IP or DNS name clients dial. Written as the profile Endpoint.
PUBLIC_HOST=vpn.example.com

# Number of client profiles to provision on first boot (printed to the log).
PEERS=1

# Tunnel subnet (assumed /24) and client DNS.
SUBNET=10.8.0.0/24
DNS=1.1.1.1

# WireGuard listen port. Default 51820 (mask). For QUIC set TRANSPORT=quic + LISTEN=443.
LISTEN=51820

# Transport: mask (UDP mask, default) or quic (QUIC on 443, blends with HTTP/3).
TRANSPORT=mask
# TLS SNI presented by the QUIC transport (quic only), e.g. www.cloudflare.com.
SNI=
