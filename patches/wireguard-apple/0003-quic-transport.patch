+++ b/Sources/WireGuardKitGo/api-apple.go
@@ -111,6 +111,22 @@ func wgSetStealthKey(keyBase64 *C.char) int32 {
 	return 0
 }
 
+// stealthTransport selects the tunnel transport: "" or "mask" use the UdpMask
+// bind (when a key is set); "quic" uses the QUIC datagram bind with stealthSNI.
+// Both are set before wgTurnOn and read when the device is created; turn-on is
+// sequential, so package globals are safe.
+var (
+	stealthTransport string
+	stealthSNI       string
+)
+
+//export wgSetTransport
+func wgSetTransport(mode *C.char, sni *C.char) int32 {
+	stealthTransport = C.GoString(mode)
+	stealthSNI = C.GoString(sni)
+	return 0
+}
+
 //export wgTurnOn
 func wgTurnOn(settings *C.char, tunFd int32) int32 {
 	logger := &device.Logger{
@@ -137,7 +153,10 @@ func wgTurnOn(settings *C.char, tunFd int32) int32 {
 	}
 	logger.Verbosef("Attaching to interface")
 	var bind conn.Bind = conn.NewStdNetBind()
-	if stealthCodec != nil {
+	if stealthTransport == "quic" {
+		bind = wgbind.NewQUIC(stealthSNI)
+		logger.Verbosef("StealthWG: QUIC transport enabled")
+	} else if stealthCodec != nil {
 		bind = wgbind.New(bind, stealthCodec)
 		logger.Verbosef("StealthWG: UdpMask bind enabled")
 	}
